# ================================================
# GitData API - Variables de Entorno
# ================================================
# Copia este archivo como .env y completa los valores.
# NUNCA commitees el .env real, solo este .env.example.

# GitHub Personal Access Token
# Scopes minimos requeridos: read:user, public_repo
# Para acceder a repos privados: repo (scope completo)
# Generar en: https://github.com/settings/tokens/new
GITHUB_TOKEN=your_github_personal_access_token_here

# Entorno de ejecucion (development | production)
# En produccion activa trustProxy en rate-limit
NODE_ENV=development

# Origen permitido para CORS (frontend)
# En desarrollo: http://localhost:5173
# En produccion: https://tu-dominio.com
ALLOWED_ORIGIN=http://localhost:5173

# Puerto del servidor API (default: 3000)
PORT=3000
